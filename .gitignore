# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/

# ============================================
# Данные (большие файлы — не для Git)
# ============================================
dataset/
dataset2/
*.csv
*.parquet

# Временные JSON-файлы consumer'а (тысячи файлов)
Kafka/temp_hdfs/

# ============================================
# Логи (создаются при каждом запуске)
# ============================================
*.log
Kafka/logs/*.log
!Kafka/logs/.gitkeep

# ============================================
# Результаты и отчёты (генерируются позже)
# ============================================
results/*.png
results/*.txt
results/*.csv
results/*.json

# ============================================
# IDE и редакторы
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# ОС
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Презентация (скриншоты — большие файлы)
# ============================================
presentation/screenshots/*.png
!presentation/screenshots/.gitkeep
